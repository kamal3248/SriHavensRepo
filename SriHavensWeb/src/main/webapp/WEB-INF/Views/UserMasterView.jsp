<div id="view_user_master_record_modal" class="modal fade" tabindex="-1"
	role="dialog" data-backdrop='static'>
	<div class="modal-dialog modal-lg  modal-dialog-centered"
		role="document">
		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title">View User Master Record</h5>
				<button type="button" class="close" data-dismiss="modal"
					aria-label="Close">
					<span aria-hidden="true">&times;</span>
				</button>
			</div>
			<div class="modal-body">
				<form class="mx-1 mx-md-4 row" id="view_user_master_record_form">
					<div class="col-md-6">
						<div class="form-group">
							<div class="form-outline flex-fill mb-0">
								<label class="form-label">UserID: </label> <span
									id="v_user_id"></span>
							</div>
						</div>

						<div class="form-group">
							<div class="form-outline flex-fill mb-0">
								<label class="form-label">Name: </label> <span
									id="v_user_name"></span>
							</div>
						</div>

						<div class="form-group">
							<div class="form-outline flex-fill mb-0">
								<label class="form-label">Email: </label> <span
									id="v_user_email"></span>
							</div>
						</div>

						<div class="form-group">
							<div class="form-outline flex-fill mb-0">
								<label class="form-label">Role: </label> <span
									id="v_user_role"> </span>
							</div>
						</div>
						<div class="form-group">
							<div class="form-outline flex-fill mb-0">
								<label class="form-label">Mobile
									Number: </label> <span id="v_mobile_number"></span>

							</div>
						</div>
						<div class="form-group">
							<div class="form-outline flex-fill mb-0">
								<label class="form-label">Last Login
									At: </label> <span id="v_last_login"></span>

							</div>
						</div>

						<div class="form-group">
							<div class="form-outline flex-fill mb-0">
								<label class="form-label">Status: </label> <span
									id="v_user_status"></span>

							</div>
						</div>
					</div>
					<div class="col-md-6">
						<div class="form-group">
							<div class="form-outline flex-fill mb-0">
								<label class="form-label">Created By: 
								</label> <span id="v_created_by"> </span>

							</div>
						</div>
						<div class="form-group">
							<div class="form-outline flex-fill mb-0">
								<label class="form-label">Created On: 
								</label> <span id="v_created_on"> </span>

							</div>
						</div>

						<div class="form-group">
							<div class="form-outline flex-fill mb-0">
								<label class="form-label">Updated By: 
								</label> <span id="v_updated_by"> </span>

							</div>
						</div>

						<div class="form-group">
							<div class="form-outline flex-fill mb-0">
								<label class="form-label">Updated On: 
								</label> <span id="v_updated_on"></span>

							</div>
						</div>

						<div class="form-group">
							<div class="form-outline flex-fill mb-0">
								<label class="form-label">Deleted By: 
								</label> <span id="v_deleted_by"></span>

							</div>
						</div>

						<div class="form-group">
							<div class="form-outline flex-fill mb-0">
								<label class="form-label">Deleted On: 
								</label> <span id="v_deleted_on"> </span>

							</div>
						</div>

						<div class="form-group">
							<div class="form-outline flex-fill mb-0">
								<label class="form-label">Last
									Password Changed By:  </label> <span id="v_pswd_changed_by"></span>

							</div>
						</div>

						<div class="form-group">
							<div class="form-outline flex-fill mb-0">
								<label class="form-label">Last
									Password Changed On:  </label> <span id="v_pswd_changed_on"></span>

							</div>
						</div>
					</div>
				</form>
			</div>
		</div>
	</div>
</div>