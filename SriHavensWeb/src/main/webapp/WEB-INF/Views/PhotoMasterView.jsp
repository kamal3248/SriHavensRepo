<div id="view_photo_master_record_modal" class="modal fade"
	tabindex="-1" role="dialog" data-backdrop='static'>
	<div class="modal-dialog modal-dialog-centered" role="document">
		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title">View Photo Master Record</h5>
				<button type="button" class="close" data-dismiss="modal"
					aria-label="Close">
					<span aria-hidden="true">&times;</span>
				</button>
			</div>
			<div class="modal-body">
				<div class="row p-2">
					<div class="col-lg-4">
						<div class="row">
							<label class="form-label" for="v_photo_master_id">photo
									ID: &nbsp;</label>
								<span id="v_photo_master_id"></span>
						</div>

						<div class="row">
								<label class="form-label" for="v_photo_master_name">Name:  &nbsp;</label>
								<span id="v_photo_master_name"></span>
								
						</div>

						<div class="row">
								<label class="form-label" for="v_photo_master_quantity">Quantity:  &nbsp;</label>
								<span id="v_photo_master_quantity"></span>
						</div>

						<div class="row">
								<label class="form-label" for="v_photo_master_price">Price
									(Rs.):  &nbsp;</label>
								<span id="v_photo_master_price"></span>
						</div>
						<div class="row">
								<label class="form-label" for="v_photo_master_status">Status:  &nbsp;</label>
								<span id="v_photo_master_status"></span>
						</div>
					</div>
					<div class="col-lg-8">
						<div class="row">
								<label class="form-label" for="v_photo_master_createdby">Created
									By:  &nbsp;</label>
									<span id="v_photo_master_createdby"></span>
						</div>
						<div class="row">
								<label class="form-label" for="v_photo_master_createdon">Created
									On:  &nbsp;</label>
									<span id="v_photo_master_createdon"></span>
						</div>
						<div class="row">
								<label class="form-label" for="v_photo_master_updatedby">Updated
									By:  &nbsp;</label>
									<span id="v_photo_master_updatedby"></span>
						</div>
						<div class="row">
								<label class="form-label" for="v_photo_master_updatedon">Updated
									On:  &nbsp;</label>
									<span id="v_photo_master_updatedon"></span>
						</div>
						<div class="row">
								<label class="form-label" for="v_photo_master_deletedby">Deleted
									By:  &nbsp;</label>
									<span id="v_photo_master_deletedby"></span>
						</div>
						<div class="row">
								<label class="form-label" for="v_photo_master_deletedon">Deleted
									On:  &nbsp;</label>
									<span id="v_photo_master_deletedon"></span>
						</div>
					</div>


				</div>
			</div>
		</div>
	</div>
</div>